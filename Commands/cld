#!/usr/bin/env bash
TOOLS="Task,Edit,Read,Update,Write,WebFetch,WebSearch,Glob,Grep,Write(./**/*),Bash(*)"

if [ "$1" = "--resume" ]; then
    shift
    claude --dangerously-skip-permissions --allowedTools "$TOOLS" -c "$@"
elif [ -z "$*" ]; then
    claude --dangerously-skip-permissions --allowedTools "$TOOLS"
else
    claude --dangerously-skip-permissions --allowedTools "$TOOLS" -p "$@"
fi