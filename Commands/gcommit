#!/usr/bin/env bash
# gcommit "<message>" — commit cleanly through pre-commit.
#
# The problem this solves: pre-commit hooks that MODIFY files (the insert-license
# header hook, ruff-format, end-of-file-fixer) abort the commit by design ("files
# were modified by this hook"). A plain `git commit` then silently does nothing
# the first time for any new/unformatted file — and that looks like success.
#
# gcommit pre-applies those fixers to the staged files first, so the in-commit
# hook run finds nothing to change and the commit lands on the first try. It then
# VERIFIES HEAD actually moved (and retries once) so a silent abort can't slip by.
#
# Usage: stage with `git add`, then `gcommit "your message"`.
set -u

message="${1:-}"
if [ -z "$message" ]; then
    echo "usage: gcommit \"<message>\"   (stage files with git add first)" >&2
    exit 1
fi

files="$(git diff --cached --name-only)"
if [ -z "$files" ]; then
    echo "gcommit: nothing staged" >&2
    exit 1
fi

# 1) Explicit ruff formatting on staged Python files (visible, intentional).
#    Prefer the repo venv's ruff (matches the project), fall back to uv/ruff.
py_files="$(echo "$files" | grep -E '\.py$' || true)"
if [ -n "$py_files" ]; then
    if [ -x ".venv/bin/ruff" ]; then ruff_cmd=".venv/bin/ruff";
    elif command -v ruff >/dev/null 2>&1; then ruff_cmd="ruff";
    elif command -v uv >/dev/null 2>&1; then ruff_cmd="uv run ruff";
    else ruff_cmd=""; fi
    if [ -n "$ruff_cmd" ]; then
        # shellcheck disable=SC2086
        $ruff_cmd check --fix $py_files >/dev/null 2>&1 || true
        # shellcheck disable=SC2086
        $ruff_cmd format $py_files >/dev/null 2>&1 || true
    fi
fi

# 2) Pre-apply ALL auto-fixing hooks (license header, ruff, EOF, etc.) with the
#    project's pinned versions so the commit-time hook run is a no-op. Non-zero
#    just means it fixed something — we re-stage below. Real lint failures still
#    block at the actual `git commit` hook run.
if command -v pre-commit >/dev/null 2>&1; then
    # shellcheck disable=SC2086
    pre-commit run --files $files >/dev/null 2>&1 || true
fi
# shellcheck disable=SC2086
git add $files

before="$(git rev-parse HEAD 2>/dev/null || echo none)"
git commit -m "$message" || true
after="$(git rev-parse HEAD 2>/dev/null || echo none)"

if [ "$before" = "$after" ]; then
    # A hook still modified files during the commit run; re-stage the same set
    # (now fixed) and retry once.
    # shellcheck disable=SC2086
    git add $files
    git commit -m "$message" || true
    after="$(git rev-parse HEAD 2>/dev/null || echo none)"
fi

if [ "$before" = "$after" ]; then
    echo "gcommit FAILED — commit did not land. Run: pre-commit run --files $files" >&2
    exit 1
fi
echo "✓ committed: $(git log --oneline -1)"
