#!/usr/bin/env -S deno run --allow-all --no-lock
import $ from "https://esm.sh/dax-sh"
import { Select } from "https://esm.sh/jsr/@cliffy/prompt"

const home = Deno.env.get("HOME")

// Find all .git dirs within 2 levels of home
const repos = []
const isRepo = async (dir) => {
    try {
        await Deno.stat(`${dir}/.git`)
        return true
    } catch {
        return false
    }
}
for await (const entry of Deno.readDir(home)) {
    if (!entry.isDirectory || entry.name.startsWith(".")) continue
    const lvl1 = `${home}/${entry.name}`
    if (await isRepo(lvl1)) repos.push(lvl1)
    // Always recurse into children — a parent repo can still contain
    // sibling repos or git worktrees (e.g. ~/repos/.git + ~/repos/dimos).
    try {
        for await (const sub of Deno.readDir(lvl1)) {
            if (!sub.isDirectory || sub.name.startsWith(".")) continue
            const lvl2 = `${lvl1}/${sub.name}`
            if (await isRepo(lvl2)) repos.push(lvl2)
        }
    } catch { /* can't read dir */ }
}

// Get branch name for each repo
const options = []
for (const dir of repos.sort()) {
    try {
        const branch = await $`git -C ${dir} branch --show-current`.text()
        const short = dir.replace(home, "~")
        options.push({
            name: `${branch.trim().padEnd(30)} ${short}`,
            value: dir,
        })
    } catch { /* skip broken repos */ }
}

const selected = await Select.prompt({
    message: "Open repo in VS Code:",
    search: true,
    options,
})

await $`code ${selected}`
