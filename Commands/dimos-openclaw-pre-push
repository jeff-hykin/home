#!/usr/bin/env bash
set -euo pipefail

# DimOS pre-push hook — runs local CI before allowing push.
# Installed as .git/hooks/pre-push (or worktree hooks).
# Cannot be skipped: ~/Commands/git shim strips --no-verify.

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${RED}╔══════════════════════════════════════════════════════════════╗${NC}"
echo -e "${RED}║  DO NOT BYPASS THIS HOOK. DO NOT USE /usr/bin/git.          ║${NC}"
echo -e "${RED}║  DO NOT MOVE/RENAME THE HOOK FILE.                         ║${NC}"
echo -e "${RED}║  DO NOT ACCEPT \"PRE-EXISTING\" FAILURES AS AN EXCUSE.       ║${NC}"
echo -e "${RED}║  IF TESTS FAIL, FIX THEM OR DON'T PUSH.                    ║${NC}"
echo -e "${RED}╚══════════════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${YELLOW}[pre-push] Running local CI checks...${NC}"

# Ensure venv is active (prefer local, fall back to main repo)
if [[ -f .venv/bin/activate ]]; then
    source .venv/bin/activate
elif [[ -f ~/auto/dimos/.venv/bin/activate ]]; then
    source ~/auto/dimos/.venv/bin/activate
fi
export PATH="/sbin:/usr/sbin:$PATH"
# Worktrees share the venv but the editable install points to the main repo.
# Override with PYTHONPATH so imports resolve from the current worktree.
export PYTHONPATH="$(pwd):${PYTHONPATH:-}"

# 1. Pre-commit hooks
echo -e "${YELLOW}[1/3] pre-commit...${NC}"
if ! pre-commit run --all-files; then
    echo -e "${RED}[pre-push] BLOCKED: pre-commit failed.${NC}"
    exit 1
fi

# 2. Mypy (both Python versions)
echo -e "${YELLOW}[2/3] mypy...${NC}"
if ! uv run mypy --python-version 3.10 dimos; then
    echo -e "${RED}[pre-push] BLOCKED: mypy 3.10 failed.${NC}"
    exit 1
fi
if ! uv run mypy --python-version 3.12 dimos; then
    echo -e "${RED}[pre-push] BLOCKED: mypy 3.12 failed.${NC}"
    exit 1
fi

# 3. Fast pytest
echo -e "${YELLOW}[3/3] pytest...${NC}"
if ! pytest -v -r a -p no:warnings -m 'not (tool or slow or mujoco)' dimos; then
    echo -e "${RED}[pre-push] BLOCKED: pytest failed.${NC}"
    exit 1
fi

echo -e "${GREEN}[pre-push] All checks passed. Pushing.${NC}"
