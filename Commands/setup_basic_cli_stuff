#!/usr/bin/env bash

# (assumes nix is installed with flakes enabled)

NIXPKGS_COMMIT="4215e62dc2cd3bc705b0a423b9719ff6be378a43"
NIXPKGS="github:NixOS/nixpkgs/$NIXPKGS_COMMIT"

#
# install deno, claude, and uv via official install scripts
#
echo ""
echo "Installing deno..."
curl -fsSL https://deno.land/install.sh | sh

echo ""
echo "Installing fnm (node version manager)..."
curl -fsSL https://fnm.vercel.app/install | bash

echo ""
echo "Installing claude..."
curl -fsSL https://claude.ai/install.sh | bash

echo ""
echo "Installing uv..."
curl -LsSf https://astral.sh/uv/install.sh | sh

#
# install nvs (nix version search)
#
echo ""
echo "Installing nvs..."
nix profile install 'https://github.com/jeff-hykin/nix_version_search_cli/archive/8053f87f566c1a4d61cfb53436eafd0331918902.tar.gz#nvs'

#
# install tools via nix flakes
#
nix_tools=(
    "dua"
    "curl"
    "git"
    "zsh"
    "git-subrepo"
    "fd"
    "eza"
    "bottom"
    "sd"
    "zellij"
    "nodePackages.ungit"
    "ssh-copy-id"
    "oxker"
    "tree"
    "htop"
    "cloc"
    "gnupg"
    "jq"
)

echo ""
echo "Installing tools via nix flakes..."
for tool in "${nix_tools[@]}"; do
    echo ""
    echo "  -> Installing $tool"
    nix profile install "$NIXPKGS#$tool"
done

#
# install only if not already available
#
install_if_missing=(
    "ripgrep:rg"
    "nano:nano"
    "git-lfs:git-lfs"
    "pre-commit:pre-commit"
    "nmap:nmap"
)

echo ""
echo "Installing tools if not already present..."
for entry in "${install_if_missing[@]}"; do
    pkg="${entry%%:*}"
    cmd="${entry##*:}"
    if ! command -v "$cmd" &>/dev/null; then
        echo ""
        echo "  -> Installing $pkg"
        nix profile install "$NIXPKGS#$pkg"
    else
        echo "  -> $cmd already exists, skipping $pkg"
    fi
done

echo ""
echo "Done!"
