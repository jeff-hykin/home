#!/usr/bin/env python3
"""
Music Discovery Tool — finds instrumental, high-energy electronic-fusion tracks.

Uses free, no-auth APIs:
  - Deezer: artist search, related artists, top tracks, BPM
  - MusicBrainz: recording lookup, genre tags, canonical IDs
  - AcousticBrainz: audio features (danceability, instrumentalness, mood)

Usage:
  music_discover [--seeds "Artist1,Artist2,..."] [--depth 1] [--min-tracks 20] [--format table|json|csv]
"""

import argparse
import json
import sys
import time
import urllib.request
import urllib.parse
import urllib.error
from dataclasses import dataclass, field, asdict
from typing import Optional

