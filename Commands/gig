#!/usr/bin/env bash
# gig — open this repo's .git/info/exclude (the local, uncommitted gitignore).
# Resolves the real common git dir, so it works correctly inside worktrees.

set -euo pipefail

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "gig: not inside a git repository" >&2
    exit 1
fi

# --git-common-dir points at the shared .git dir even from a linked worktree,
# where .git is a file and info/exclude lives in the common dir.
common_dir="$(git rev-parse --path-format=absolute --git-common-dir)"
exclude_file="$common_dir/info/exclude"

if [ ! -e "$exclude_file" ]; then
    mkdir -p "$common_dir/info"
    touch "$exclude_file"
fi

if command -v code >/dev/null 2>&1; then
    code "$exclude_file"
else
    "${EDITOR:-nano}" "$exclude_file"
fi
