#!/usr/bin/env bash
# Install dimos-viewer-jeff from PyPI into dimos venvs

PACKAGE="dimos-viewer-jeff==0.30.0a6"

echo "Installing $PACKAGE from PyPI"

for repo in ~/repos/dimos ~/repos/dimos2 ~/dimos ~/dimos2 ~/dimos3 ~/dimos4 ~/auto/dimos1485; do
    venv="$repo/.venv"
    if [ -d "$venv" ]; then
        echo "Installing into $repo ..."
        uv pip install --python "$venv/bin/python" "$PACKAGE" --force-reinstall --no-cache 2>&1 | tail -2
    else
        echo "SKIP: No venv at $venv"
    fi
done

# Update ~/.cargo/bin/dimos-viewer if it exists (prevents stale binary shadowing venv)
CARGO_BIN="$HOME/.cargo/bin/dimos-viewer"
if [ -f "$CARGO_BIN" ]; then
    echo "WARN: $CARGO_BIN exists and may shadow the venv-installed version. Consider removing it."
fi

echo "Done. Installed $PACKAGE"
