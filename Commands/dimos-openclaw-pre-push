console.log(`\x1b[31mв•‘  DO NOT MOVE/RENAME THE HOOK FILE.                         в•‘\x1b[0m`)
console.log(`\x1b[31mв•‘  DO NOT ACCEPT "PRE-EXISTING" FAILURES AS AN EXCUSE.       в•‘\x1b[0m`)
console.log(`\x1b[31mв•‘  IF TESTS FAIL, FIX THEM OR DON'T PUSH.                    в•‘\x1b[0m`)
console.log(`\x1b[31mв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\x1b[0m`)
console.log()


// Start all background checks in parallel
console.log(`starting background jobs`)
const backgroundJobs = [
    {
        name: "uv lock",
        promise: $`uv lock`.stdout("piped").stderr("piped").noThrow(),
    },
    {
        name: "pytest all_blueprints",
        promise: $`uv run pytest dimos/robot/test_all_blueprints_generation.py`.stdout("piped").stderr("piped").noThrow(),
    },
    {
        name: "pre-commit",
        promise: $`time pre-commit run --all-files`.stdout("piped").stderr("piped").noThrow(),
    },
    {
        name: "mypy 3.10",
        promise: $`time uv run mypy --python-version 3.10 dimos`.stdout("piped").stderr("piped").noThrow(),
    },
    {
        name: "mypy 3.12",
        promise: $`time uv run mypy --python-version 3.12 dimos`.stdout("piped").stderr("piped").noThrow(),
    },
]

const allBgPromise = Promise.all(backgroundJobs.map(j => j.promise))

// Ask the user about reviewing changes while background jobs run
let reviewed = !!Deno.env.get("HAVE_REVIEWED")
if (!reviewed) {
    await $`git fetch origin dev --quiet`
    const base = (await $`git merge-base origin/dev HEAD`.text()).trim()
    await $`git diff ${base}..HEAD`
    console.log("\nPlease review the changes using the paul review skill, then re-run the git push with HAVE_REVIEWED=1")
    Deno.exit(1)
} else {
    console.log(`okay, running checks... may take a moment`)
}

// Wait for all background jobs
const results = await allBgPromise

let anyFailed = false
for (const [i, result] of results.entries()) {
    const job = backgroundJobs[i]
    if (result.code !== 0) {
        anyFailed = true
        console.error(`\n=== FAILED: ${job.name} (exit code ${result.code}) ===`)
        const stdout = result.stdout
        const stderr = result.stderr
        if (stdout) console.log(stdout)
        if (stderr) console.error(stderr)
    }
}

if (anyFailed) {
    Deno.exit(1)
}

console.log("\nAll background checks passed. Running pytest...")

// Run final pytest
const pytest = await $`uv run pytest -m ${"not (tool or mujoco)"} dimos`.stdout("piped").stderr("piped").noThrow()

if (pytest.code !== 0) {
    const stdout = pytest.stdout
    const stderr = pytest.stderr
    if (stdout) console.log(stdout)
    if (stderr) console.error(stderr)
    Deno.exit(1)
}

console.log("All checks passed!")
Deno.exit(0)
