#!/usr/bin/env bash

LOG="$HOME/sys.log"
LOG_DIR="$HOME/sys_logs"
INTERVAL=5  # seconds between snapshots

mkdir -p "$LOG_DIR"

# Archive existing log
if [[ -f "$LOG" ]]; then
    DATETIME=$(date +"%Y-%m-%d_%H-%M-%S")
    mv "$LOG" "$LOG_DIR/${DATETIME}.log"
    echo "Archived previous log to $LOG_DIR/${DATETIME}.log"
fi

dump_snapshot() {
    echo "================================================================"
    echo "SNAPSHOT: $(date '+%Y-%m-%d %H:%M:%S.%3N')"
    echo "================================================================"

    echo "--- UPTIME / LOAD ---"
    uptime

    echo "--- MEMORY ---"
    free -h
    echo ""
    cat /proc/meminfo

    echo "--- CPU STATS (vmstat) ---"
    vmstat 1 3

    echo "--- TOP PROCESSES (CPU) ---"
    ps aux --sort=-%cpu | head -30

    echo "--- TOP PROCESSES (MEM) ---"
    ps aux --sort=-%mem | head -30

    echo "--- OPEN FILE COUNTS ---"
    echo "System-wide (file-nr: open/free/max):"
    cat /proc/sys/fs/file-nr
    echo "Per-process top open fd counts:"
    find /proc -maxdepth 2 -name fd -type d 2>/dev/null \
        | awk -F/ '{print $3}' \
        | while read pid; do
            count=$(ls /proc/$pid/fd 2>/dev/null | wc -l)
            name=$(cat /proc/$pid/comm 2>/dev/null || echo "?")
            echo "$count $pid $name"
          done \
        | sort -rn | head -20

    echo "--- DISK USAGE ---"
    df -h

    echo "--- DISK I/O (iostat) ---"
    iostat -x 1 2 2>/dev/null || echo "(iostat not available)"

    echo "--- NETWORK SOCKETS ---"
    /usr/bin/ss -s
    echo ""
    /usr/bin/ss -tulpn

    echo "--- DMESG (last 50 lines) ---"
    dmesg --time-format iso 2>/dev/null | tail -50 || dmesg | tail -50

    echo "--- JOURNAL ERRORS (last 30) ---"
    journalctl -p err..emerg -n 30 --no-pager 2>/dev/null || echo "(journalctl not available)"

    echo "--- OOM KILLER (last hits) ---"
    dmesg 2>/dev/null | grep -i "oom\|killed process\|out of memory" | tail -20 || true

    echo "--- SWAP ---"
    swapon --show 2>/dev/null || true
    cat /proc/swaps

    echo "--- INTERRUPTS SUMMARY ---"
    head -5 /proc/interrupts

    echo "--- THREADS / TASKS ---"
    echo "Total threads: $(ps -eo nlwp | tail -n +2 | awk '{n+=$1} END {print n}')"
    echo "Total processes: $(ps aux | wc -l)"

    echo ""
}

echo "Starting syslog loop (interval: ${INTERVAL}s) -> $LOG"
echo "PID: $$"

while true; do
    dump_snapshot >> "$LOG" 2>&1
    sleep "$INTERVAL"
done
