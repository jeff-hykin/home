#!/usr/bin/env bash
branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
if [ -z "$branch" ]; then
    echo "Not in a git repo"
    exit 1
fi
url=$(gh pr view "$branch" --json url --jq .url 2>/dev/null)
if [ -z "$url" ]; then
    echo "No PR found for branch: $branch"
    exit 1
fi
echo "Opening $url"
open "$url"
