#!/bin/sh
# Kill all dimos application and Unity processes

echo "Looking for dimos and Unity processes..."

# Process patterns
dimos_pattern='dimos run |dimos-viewer|dimos[0-9]*/.venv/bin/python3|repos/dimos/.venv/bin/python3'
native_pattern='result/bin/(local_planner|path_follower|terrain_analysis|far_planner|pct_planner|pgo|rtab_map|gazebo_native|fastlio2_native)'
unity_pattern='Model\.x86_64|Unity|unity_envs'
gazebo_pattern='gzserver|gzclient|ign-gazebo|ignition-gazebo|gz sim '
ros_pattern='ros-navigation-autonomy-stack|/opt/ros/|ros2|roscore|rosmaster|roslaunch|rosout|joy_node|teleop_twist_joy|ros2_daemon'
# tcpdumps launched by anything dimos-related (orphaned when parent crashes,
# since fastlio2 spawns tcpdump with start_new_session=True).
tcpdump_pattern='tcpdump.*dimos|dimos.*tcpdump'
all_pattern="$dimos_pattern|$native_pattern|$unity_pattern|$gazebo_pattern|$ros_pattern|$tcpdump_pattern"

find_pids() {
    ps aux | grep -E "$1" | grep -v grep | grep -v "claude" | awk '{print $2}'
}

all_pids=$(find_pids "$all_pattern" | xargs)

if [ -z "$all_pids" ]; then
    echo "No dimos or Unity processes found."
else
    echo "Killing PIDs: $all_pids"
    kill -9 $all_pids 2>/dev/null

    # Verify
    sleep 0.5
    remaining=$(find_pids "$all_pattern" | xargs)

    if [ -z "$remaining" ]; then
        echo "All dimos and Unity processes killed."
    else
        echo "Some processes still running: $remaining"
        echo "Retrying..."
        kill -9 $remaining 2>/dev/null
    fi
fi

# Kill anything using these ports
for port in 7779 9090 3030 9876 9877 10000; do
    port_pids=$(lsof -ti :$port 2>/dev/null)
    if [ -n "$port_pids" ]; then
        echo "Killing processes on port $port: $port_pids"
        echo "$port_pids" | xargs kill -9 2>/dev/null
    fi
done

# Kill docker containers related to dimos or nav stack
if command -v docker >/dev/null 2>&1; then
    dimos_containers=$(docker ps -q --filter "name=dimos" --filter "name=ognav" --filter "name=rosnav" --filter "name=nav_stack" 2>/dev/null | sort -u)
    if [ -n "$dimos_containers" ]; then
        echo "Stopping docker containers..."
        echo "$dimos_containers" | xargs docker kill 2>/dev/null
        echo "$dimos_containers" | xargs docker rm -f 2>/dev/null
        echo "Docker containers stopped."
    else
        echo "No dimos Docker containers running."
    fi
fi
