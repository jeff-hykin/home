#!/usr/bin/env bash
# Install the custom dimos-viewer wheel (with --connect fix) into dimos venvs

WHEELS_DIR="$HOME/repos/dimos-viewer/target/wheels"
if ! [ -d "$WHEELS_DIR" ]
then
    WHEELS_DIR="$HOME/auto/dimos-viewer/target/wheels"
fi

# Find the most recently modified dimos_viewer wheel
WHEEL="$(ls -t "$WHEELS_DIR"/dimos_viewer-*.whl 2>/dev/null | head -1)"

if [ -z "$WHEEL" ]; then
    echo "ERROR: No dimos_viewer wheel found in $WHEELS_DIR"
    echo "Build it first: cd ~/repos/dimos-viewer/dimos && maturin build --release"
    exit 1
fi

echo "Using wheel: $(basename "$WHEEL")"

for repo in ~/dimos2 ~/dimos ~/dimos3; do
    venv="$repo/.venv"
    if [ -d "$venv" ]; then
        echo "Installing into $repo ..."
        uv pip install --python "$venv/bin/python" "$WHEEL" --force-reinstall 2>&1 | tail -2
    else
        echo "SKIP: No venv at $venv"
    fi
done

echo "Done. Installed dimos-viewer $(basename "$WHEEL" | sed 's/dimos_viewer-//;s/-cp.*//')"
